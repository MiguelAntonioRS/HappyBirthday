<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Feliz cumpleaños Margot</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <canvas id="scene"></canvas>

  <!-- Texto central accesible -->
  <div id="centerText" aria-hidden="false">
    <h1>Feliz cumpleaños<br/><span class="name">Margot</span></h1>
    <p class="subtitle">Que tu día brille como esta galaxia ✨</p>
  </div>

  <!-- Barra inferior con mensajes que fluyen -->
  <div id="bottomTicker" aria-hidden="true">
    <div class="ticker-track" id="tickerTrack">
      <!-- Mensajes añadidos por JS -->
    </div>
  </div>

  <!-- Botón de reproducción -->
  <button id="musicBtn" class="music-btn" aria-label="Reproducir música">▶︎</button>

  <!-- Audio: coloca un archivo llamado music.mp3 en esta carpeta si quieres música -->
  <audio id="bgMusic" loop preload="auto">
    <source src="music.mp3" type="audio/mpeg">
    Tu navegador no soporta reproducción de audio.
  </audio>

  <script src="app.js"></script>
  <script>
    (function(){
      const btn = document.getElementById('musicBtn');
      const audio = document.getElementById('bgMusic');
      let playing = false;

      function updateBtn() {
        btn.textContent = playing ? '❚❚' : '▶︎';
        btn.setAttribute('aria-pressed', String(playing));
      }

      btn.addEventListener('click', async () => {
        try {
          if (!playing) {
            await audio.play();
            playing = true;
          } else {
            audio.pause();
            playing = false;
          }
        } catch (e) {
          console.warn('Reproducción bloqueada o fallida', e);
        }
        updateBtn();
      });

      function firstInteract() {
        if (!playing) {
          audio.play().then(() => { playing = true; updateBtn(); })
                      .catch(()=>{/* no crítico */});
        }
        window.removeEventListener('touchstart', firstInteract);
        window.removeEventListener('click', firstInteract);
      }
      window.addEventListener('touchstart', firstInteract, {passive: true});
      window.addEventListener('click', firstInteract, {once: true});
      updateBtn();
    })();
  </script>
</body>
</html>
