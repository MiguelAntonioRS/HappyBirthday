cat > app.js <<'JS'
// Animación: galaxia + flores orbitando + ticker de mensajes
(() => {
  const canvas = document.getElementById('scene');
  const ctx = canvas.getContext('2d', { alpha: true });

  let W = canvas.width = innerWidth;
  let H = canvas.height = innerHeight;
  let centerX = W / 2;
  let centerY = H / 2;

  window.addEventListener('resize', () => {
    W = canvas.width = innerWidth;
    H = canvas.height = innerHeight;
    centerX = W / 2;
    centerY = H / 2;
    initParticles();
  });

  // ESTRELLAS / PARTICULAS DE FONDO
  const stars = [];
  function initStars() {
    stars.length = 0;
    const count = Math.floor((W * H) / 10000);
    for (let i = 0; i < count; i++) {
      stars.push({
        x: Math.random() * W,
        y: Math.random() * H,
        r: Math.random() * 1.5 + 0.2,
        alpha: 0.2 + Math.random() * 0.9,
        tw: Math.random() * 120
      });
    }
  }

  // GALAXIA (partículas en espiral)
  const galaxyParticles = [];
  function initGalaxy() {
    galaxyParticles.length = 0;
    const arms = 3;
    const particles = 700;
    for (let i = 0; i < particles; i++) {
      const arm = i % arms;
      const radius = Math.pow(Math.random(), 1.8) * Math.min(W, H) * 0.4;
      const angle = (i / particles) * Math.PI * 2 + arm * 0.8;
      const sway = (Math.random() - 0.5) * 0.6;
      galaxyParticles.push({ angle, radius, sway, speed: 0.0005 + Math.random() * 0.0019, hue: 220 + Math.random() * 120, size: Math.random() * 1.3 + 0.3 });
    }
  }

  // FLORES que orbitan
  const flowers = [];
  function Flower(orbitRadius, angleOffset, size, colorHue, speed) {
    this.orbitRadius = orbitRadius;
    this.angle = angleOffset;
    this.size = size;
    this.hue = colorHue;
    this.speed = speed;
    this.pulse = Math.random() * 2 * Math.PI;
  }
  Flower.prototype.update = function (dt) {
    this.angle += this.speed * dt;
    this.pulse += 0.004 * dt;
  };
  Flower.prototype.draw = function (ctx) {
    const x = centerX + Math.cos(this.angle) * this.orbitRadius;
    const y = centerY + Math.sin(this.angle) * this.orbitRadius * 0.72;
    const s = this.size * (1 + Math.sin(this.pulse) * 0.14);

    // pétalos
    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(Math.sin(this.angle * 2) * 0.5);
    for (let p = 0; p < 6; p++) {
      ctx.rotate((Math.PI * 2) / 6);
      ctx.beginPath();
      ctx.ellipse(0 + s * 6, 0, s * 6, s * 12, Math.PI / 6, 0, Math.PI * 2);
      ctx.fillStyle = `hsla(${this.hue + p * 6}, 85%, ${50 - p * 3}%, 0.95)`;
      ctx.fill();
      ctx.closePath();
    }
    // centro
    ctx.beginPath();
    ctx.arc(0, 0, s * 4.2, 0, Math.PI * 2);
    ctx.fillStyle = `hsla(${this.hue - 20}, 80%, 60%, 0.98)`;
    ctx.fill();
    ctx.restore();
  };

  function initFlowers() {
    flowers.length = 0;
    const count = Math.floor(Math.max(6, Math.min(18, (W + H) / 250)));
    for (let i = 0; i < count; i++) {
      const r = (Math.min(W, H) * 0.18) + (i * (Math.min(W, H) * 0.03));
      const angle = (Math.PI * 2 / count) * i + Math.random() * 0.5;
      const size = 3 + Math.random() * 1.4;
      flowers.push(new Flower(r, angle, size, 300 - i * 10 + Math.random() * 40, 0.001 + Math.random() * 0.003));
    }
  }

  // Mensajes inferiores (ticker)
  const messages = [
    "Que cada estrella te traiga un deseo cumplido, Margot 🌟",
    "Que tu risa siga iluminando todo a tu alrededor 🌼",
    "Un abrazo grande lleno de cariño y colores 🎁",
    "Hoy celebramos tu magia: alegría, luz y flores 🌸",
    "Que la dicha te acompañe hoy y siempre, amiga 💖",
    "Brilla sin miedo — feliz cumpleaños, Margot ✨"
  ];

  // Inicia el ticker en el DOM
  function initTicker() {
    const track = document.getElementById('tickerTrack');
    track.innerHTML = '';
    for (let loop = 0; loop < 2; loop++) {
      messages.forEach(msg => {
        const span = document.createElement('span');
        span.className = 'ticker-item';
        span.textContent = msg;
        track.appendChild(span);
      });
    }
  }

  // Mensajes flotantes que suben desde abajo
  const floating = [];
  function spawnFloating() {
    const texts = [
      "Te quiero mucho, Margot 💕",
      "Siempre a tu lado, amiga 🥂",
      "Que la vida te regale sonrisas 🌷",
      "Hoy y siempre, celebro contigo 🌟"
    ];
    const text = texts[Math.floor(Math.random() * texts.length)];
    floating.push({
      text,
      x: centerX + (Math.random() - 0.5) * 160,
      y: H - 40,
      alpha: 0.95,
      life: 0,
      speedY: 0.35 + Math.random() * 0.3,
      size: 18 + Math.random() * 6
    });
    if (floating.length > 6) floating.shift();
  }

  function initParticles() {
    initStars();
    initGalaxy();
    initFlowers();
    initTicker();
  }
  initParticles();

  let last = performance.now();
  function animate(now) {
    const dt = now - last;
    last = now;

    ctx.clearRect(0, 0, W, H);

    ctx.globalCompositeOperation = 'lighter';
    for (let s of stars) {
      s.tw += dt * 0.001;
      const a = s.alpha * (0.7 + 0.3 * Math.sin(s.tw * 2));
      ctx.fillStyle = `rgba(255,255,255,${a})`;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
    }

    for (let p of galaxyParticles) {
      p.angle += p.speed * dt;
      const x = centerX + Math.cos(p.angle + p.sway) * p.radius * (1 + Math.sin(p.angle) * 0.02);
      const y = centerY + Math.sin(p.angle + p.sway) * p.radius * 0.72 * (1 + Math.cos(p.angle) * 0.02);
      const size = p.size * (0.6 + 0.8 * (Math.sin(p.angle * 7) * 0.5 + 0.5));
      ctx.beginPath();
      ctx.fillStyle = `hsla(${p.hue}, 90%, 62%, 0.9)`;
      ctx.globalAlpha = 0.9 * (0.6 + Math.random() * 0.4);
      ctx.arc(x, y, size, 0, Math.PI * 2);
      ctx.fill();
    }

    ctx.globalAlpha = 1;

    const lg = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, Math.min(W, H) * 0.45);
    lg.addColorStop(0, 'rgba(255,240,240,0.25)');
    lg.addColorStop(0.35, 'rgba(180,150,220,0.06)');
    lg.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = lg;
    ctx.fillRect(0, 0, W, H);

    for (let f of flowers) {
      f.update(dt);
      f.draw(ctx);
    }

    ctx.save();
    ctx.font = `bold ${Math.max(28, Math.min(140, W * 0.07))}px "Segoe UI", Roboto, Arial`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.shadowColor = 'rgba(220,150,240,0.22)';
    ctx.shadowBlur = 40;
    ctx.fillStyle = 'rgba(255,245,235,0.95)';
    ctx.fillText('Feliz cumpleaños', centerX, centerY - (H * 0.04));
    ctx.font = `bold ${Math.max(20, Math.min(96, W * 0.05))}px "Segoe UI", Roboto, Arial`;
    ctx.fillStyle = 'rgba(255,220,255,0.98)';
    ctx.fillText('Margot', centerX, centerY + (H * 0.04));
    ctx.restore();

    for (let i = floating.length - 1; i >= 0; i--) {
      const m = floating[i];
      m.y -= m.speedY * dt * 0.05;
      m.alpha -= 0.0007 * dt;
      m.life += dt;
      ctx.save();
      ctx.globalAlpha = Math.max(0, m.alpha);
      ctx.font = `600 ${m.size}px "Segoe UI", Roboto, Arial`;
      ctx.fillStyle = 'white';
      ctx.textAlign = 'center';
      ctx.fillText(m.text, m.x, m.y);
      ctx.restore();
      if (m.alpha <= 0 || m.y < -40) floating.splice(i, 1);
    }

    if (Math.random() < 0.009) spawnFloating();

    requestAnimationFrame(animate);
  }
  requestAnimationFrame(animate);

  for (let i = 0; i < 2; i++) {
    setTimeout(spawnFloating, 800 * i + 400);
  }

  const track = document.getElementById('tickerTrack');
  track.style.animationPlayState = 'running';

  window.HB = {
    addMessage(msg) {
      messages.push(msg);
      initTicker();
    },
    setName(name) {
      const el = document.querySelector('#centerText .name');
      if (el) el.textContent = name;
    },
    spawnFloating(text) {
      if (text) {
        floating.push({
          text,
          x: centerX + (Math.random() - 0.5) * 160,
          y: H - 40,
          alpha: 0.98,
          life: 0,
          speedY: 0.35 + Math.random() * 0.3,
          size: 18 + Math.random() * 6
        });
      } else spawnFloating();
    }
  };

  function initStars() {
    stars.length = 0;
    const count = Math.floor((W * H) / 10000);
    for (let i = 0; i < count; i++) {
      stars.push({
        x: Math.random() * W,
        y: Math.random() * H,
        r: Math.random() * 1.5 + 0.2,
        alpha: 0.2 + Math.random() * 0.9,
        tw: Math.random() * 120
      });
    }
  }
})();
