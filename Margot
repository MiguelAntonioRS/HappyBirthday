/* Reset básico */
* { box-sizing: border-box; margin: 0; padding: 0; }

html, body { height: 100%; width: 100%; background: #000; font-family: "Segoe UI", Roboto, Arial, sans-serif; color: #fff; overflow: hidden; }

/* Canvas ocupa toda la pantalla */
#scene {
  display: block;
  width: 100vw;
  height: 100vh;
  background: radial-gradient(ellipse at center, #000011 0%, #000 60%);
}

/* Texto central */
#centerText {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%,-50%);
  text-align: center;
  pointer-events: none;
  z-index: 5;
  mix-blend-mode: screen;
}

#centerText h1 {
  font-size: clamp(2rem, 6vw, 5rem);
  letter-spacing: 0.02em;
  line-height: 0.9;
  text-shadow: 0 0 6px rgba(255,200,240,0.12), 0 0 18px rgba(255,120,200,0.18), 0 0 40px rgba(255,90,180,0.12);
  color: #ffefd9;
  margin-bottom: 0.4rem;
}

#centerText h1 .name {
  display: inline-block;
  color: #ffe7f3;
  background: linear-gradient(90deg, rgba(255,255,255,0.18), rgba(255,160,220,0.08));
  padding: 0.05em 0.3em;
  border-radius: 0.25em;
  transform: translateZ(0);
  box-shadow: 0 6px 20px rgba(200,80,170,0.12);
}

#centerText .subtitle {
  margin-top: 0.6rem;
  color: #cfe7ff;
  opacity: 0.9;
  font-size: clamp(0.9rem, 2vw, 1.2rem);
}

/* Barra inferior (ticker) */
#bottomTicker {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 20px;
  z-index: 6;
  pointer-events: none;
  overflow: hidden;
}

.ticker-track {
  display: inline-block;
  white-space: nowrap;
  will-change: transform;
  animation: tickerScroll 22s linear infinite;
}

/* Cada mensaje dentro del ticker */
.ticker-item {
  display: inline-block;
  margin: 0 2.5rem;
  font-weight: 600;
  color: #fff;
  padding: 0.35rem 0.6rem;
  background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
  border-radius: 999px;
  box-shadow: 0 6px 24px rgba(100,40,120,0.08);
  backdrop-filter: blur(4px);
}

@keyframes tickerScroll {
  0% { transform: translateX(0%); }
  100% { transform: translateX(-50%); } /* contenido debe repetirse para efecto infinito */
}

/* Botón de música */
.music-btn {
  position: fixed;
  right: 18px;
  bottom: 18px;
  z-index: 9;
  background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
  border: none;
  color: #fff;
  width: 54px;
  height: 54px;
  border-radius: 50%;
  font-size: 20px;
  cursor: pointer;
  box-shadow: 0 8px 30px rgba(50,10,80,0.35);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
}

/* pequeños mensajes que suben (pop) */
